<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>내 지점 지도</title>

<script src="https://dapi.kakao.com/v2/maps/sdk.js?appkey=ad18dd7fe3b2eaa89de6a8900e1ace2f"></script>

<style>
body {margin:0;}
#map {width:100%; height:100vh;}
</style>

</head>

<body>

<div id="map"></div>

<script>

var mapContainer = document.getElementById('map');

var mapOption = {
center: new kakao.maps.LatLng(37.5665, 126.9780),
level: 7
};

var map = new kakao.maps.Map(mapContainer, mapOption);

var locations = [

{title:"홍대점", lat:37.5563, lng:126.9220},

{title:"망원점", lat:37.5560, lng:126.9010},

{title:"합정점", lat:37.5490, lng:126.9130}

];

locations.forEach(function(loc){

var markerPosition = new kakao.maps.LatLng(loc.lat, loc.lng);

var marker = new kakao.maps.Marker({
map: map,
position: markerPosition
});

});


</script>

</body>
</html>
